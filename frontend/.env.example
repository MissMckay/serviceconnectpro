# Backend API (use full URL when backend runs on different origin)
VITE_API_URL=http://localhost:5000/api
# Or use proxy: VITE_API_BASE_URL=/api and configure Vite proxy to http://localhost:5000
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_PROXY_TARGET=http://localhost:5000
# Deployed apps should allow slower cold starts before aborting GET requests.
VITE_DEFAULT_GET_TIMEOUT_MS=12000
