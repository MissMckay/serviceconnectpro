PORT=5000
MONGO_URI_STANDARD=mongodb://username:password@host1:27017,host2:27017,host3:27017/serviceconnect_new?replicaSet=atlas-xxxx-shard-0&ssl=true&authSource=admin&retryWrites=true&w=majority
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
JWT_SECRET=replace-with-a-secure-secret
CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
CORS_ORIGIN_REGEX=^https://serviceconnectpro-.*\.vercel\.app$

# Recommended production tuning for Render + Mongo Atlas
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=20000
MONGO_HEARTBEAT_FREQUENCY_MS=10000
MONGO_CONNECT_RETRIES=5
MONGO_CONNECT_BASE_DELAY_MS=2000
MONGO_RECONNECT_BASE_DELAY_MS=3000
MONGO_RECONNECT_MAX_DELAY_MS=30000
MONGO_DEGRADED_COOLDOWN_MS=15000
MONGO_VERIFY_RETRIES=3
MONGO_VERIFY_RETRY_DELAY_MS=250
MONGO_VERIFY_WITH_PING=false

SERVICES_QUERY_TIMEOUT_MS=6000
SERVICES_REFRESH_TIMEOUT_MS=1500
