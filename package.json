{
  "name": "serviceconnect",
  "private": true,
  "scripts": {
    "build": "npm --prefix frontend run build",
    "dev": "concurrently -k -s first -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "start": "concurrently -n backend,frontend -c blue,green \"npm:start:backend\" \"npm:start:frontend\"",
    "start:backend": "npm --prefix backend start",
    "start:frontend": "npm --prefix frontend run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "jsonwebtoken": "^9.0.3",
    "react-router-dom": "^7.13.0"
  }
}
